meta {
  name: Create Category
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/categories
  body: json
  auth: basic
}

auth:basic {
  username: {{username}}
  password: {{password}}
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "code": "ELECTRONICS",
    "name": "Electronics",
    "description": "Electronic warehouse goods"
  }
}
