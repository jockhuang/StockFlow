meta {
  name: Update Inventory Item
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/api/inventory-items/1
  body: json
  auth: basic
}

auth:basic {
  username: {{username}}
  password: {{password}}
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "sku": "WH-1001",
    "name": "Barcode Scanner Pro",
    "quantity": 20,
    "location": "A-02",
    "categoryId": 1
  }
}
