  username: {{username}}
  password: {{password}}
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "code": "ADMIN",
    "name": "Administrator",
    "description": "Full access role",
    "resourceIds": [1, 2, 3, 4, 5, 6]
  }
}
